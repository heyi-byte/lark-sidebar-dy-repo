{
  "name": "lark-sidebar-pay",
  "private": true,
  "version": "1.0.0",
  "output": "dist",
  "scripts": {
    "dev": "vite",
    "dev:xhs": "cross-env VITE_CLIENT=xhs vite",
    "dev:douyin": "cross-env VITE_CLIENT=douyin vite",
    "dev:bili": "cross-env VITE_CLIENT=bilibili vite",
    "build": "vite build",
    "build:xhs": "cross-env VITE_CLIENT=xhs vite build",
    "build:douyin": "cross-env VITE_CLIENT=douyin vite build",
    "build:bili": "cross-env VITE_CLIENT=bilibili vite build",
    "pack": "vite build && node scripts/build-zip.js",
    "pack:xhs": "cross-env VITE_CLIENT=xhs sh -c 'vite build && node scripts/build-zip.js'",
    "pack:douyin": "cross-env VITE_CLIENT=douyin sh -c 'vite build && node scripts/build-zip.js'",
    "pack:bili": "cross-env VITE_CLIENT=bilibili sh -c 'vite build && node scripts/build-zip.js'",
    "preview": "vite preview --port 4173",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .vue,.js,.ts",
    "lint:fix": "eslint src --ext .vue,.js,.ts --fix"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@lark-base-open/js-sdk": "^0.5.0",
    "axios": "^1.7.7",
    "echarts": "^5.6.0",
    "echarts-liquidfill": "^3.1.0",
    "element-plus": "^2.3.6",
    "pinia": "^3.0.4",
    "qrcode": "^1.5.4",
    "reset-css": "^5.0.1",
    "vue": "^3.2.37",
    "vue-echarts": "^6.7.3",
    "vue-i18n": "^9.4.1",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitejs/plugin-vue": "^3.0.1",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "axios-mock-adapter": "^2.1.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^9.33.0",
    "globals": "^15.15.0",
    "jsdom": "^28.1.0",
    "jszip": "^3.10.1",
    "prettier": "^3.8.3",
    "unplugin-auto-import": "^0.16.4",
    "unplugin-vue-components": "^0.25.1",
    "vite": "^3.2.11",
    "vitest": "1.6.0",
    "vue-eslint-parser": "^9.4.3"
  }
}
